# Copy to .env — PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/furniture_ecm"

# Tối thiểu 16 ký tự
AUTH_SECRET="change-me-to-a-long-random-string-for-development"

NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Thông báo chung (banner dưới header shop & phía trên khu vực nội dung admin). Để trống = ẩn.
NEXT_PUBLIC_APP_MESSAGE=""
# info | warning | promo — kiểu nền banner storefront (admin vẫn đọc biến này cho kind)
NEXT_PUBLIC_APP_MESSAGE_KIND="info"
# Tuỳ chọn: riêng admin; nếu trống thì dùng NEXT_PUBLIC_APP_MESSAGE
NEXT_PUBLIC_ADMIN_APP_MESSAGE=""

# Sidebar trang /account (tuỳ chọn — hiển thị Email liên hệ / Website)
NEXT_PUBLIC_CONTACT_EMAIL=""

# Floating rail — link m.me (Messenger fanpage) và Zalo OA / cá nhân
# Ví dụ: https://m.me/TenTrang  hoặc https://www.facebook.com/messages/t/...
NEXT_PUBLIC_MESSENGER_URL="https://m.me/TenTrangFacebook"
# Ví dụ: https://zalo.me/0123456789 hoặc mã QR OA
NEXT_PUBLIC_ZALO_URL="https://zalo.me/0123456789"
NEXT_PUBLIC_HOTLINE_TEL="0931799744"

# GA / Meta (sau khi bấm Chấp nhận cookie trên storefront)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""

# Cloudinary — upload ảnh (admin / account / chat). Bỏ trống hoặc không set → upload API trả 503.
# Cách 1 (khuyến nghị): copy chuỗi từ Dashboard → API Keys → "Environment variable"
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
#
# Cách 2: tách 3 biến (không cần CLOUDINARY_URL nếu set đủ ba dòng dưới)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Redis (BullMQ worker — npm run worker; badge chat admin realtime qua SSE + pub/sub)
REDIS_URL="redis://127.0.0.1:6379"

# Chat: file lưu local, ảnh lên Cloudinary — job worker xóa sau N giờ (mặc định 1h)
# CHAT_UPLOAD_RETENTION_HOURS=1
# hoặc CHAT_UPLOAD_RETENTION_MS=3600000

# OTP dev: trả code trong JSON response
OTP_DEBUG="1"
