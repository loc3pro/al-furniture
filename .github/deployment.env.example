# Danh sách biến deploy — khai báo trên GitHub, không commit giá trị thật.
# Repo → Settings → Secrets and variables → Actions
#
# Secrets (SSH + app — nhạy cảm):
#   VPS_HOST, VPS_USER, VPS_SSH_PASSWORD
#   DATABASE_URL, AUTH_SECRET, CLOUDINARY_URL
#   CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET, LIBRE_TRANSLATE_KEY
#
# Variables (có thể public — tab Variables):
#   VPS_APP_DIR
#   NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_GOOGLE_CLIENT_ID
#   NEXT_PUBLIC_MESSENGER_URL, NEXT_PUBLIC_ZALO_URL, NEXT_PUBLIC_HOTLINE_TEL
#   NEXT_PUBLIC_GA_ID, NEXT_PUBLIC_FB_PIXEL_ID, NEXT_PUBLIC_CONTACT_EMAIL
#   NEXT_PUBLIC_APP_MESSAGE, NEXT_PUBLIC_ADMIN_APP_MESSAGE, NEXT_PUBLIC_APP_MESSAGE_KIND
#   REDIS_URL, REDIS_CACHE_PREFIX, OTP_DEBUG, SESSION_COOKIE_SECURE
#   LIBRE_TRANSLATE_URL, CHAT_UPLOAD_RETENTION_MS, CHAT_UPLOAD_RETENTION_HOURS
#   CLOUDINARY_CLOUD_NAME
#
# Docker Compose trên VPS: DATABASE_URL host = db, REDIS_URL host = redis.
# Workflow deploy ghi file .env trên VPS trước khi docker compose up.
