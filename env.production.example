# --- Docker Compose trên VPS (khuyến nghị) ---
# DATABASE_URL / REDIS_URL phải dùng tên service trong docker-compose.yml (db, redis).
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://example.com
AUTH_SECRET=replace-with-openssl-rand-base64-48
# Cookie session: mặc định chỉ bật Secure khi NEXT_PUBLIC_SITE_URL là https://
# (truy cập http://IP:3000 không lưu được cookie nếu Secure=true). Ghi đè: 0 | 1
# SESSION_COOKIE_SECURE=0
DATABASE_URL=postgresql://postgres:postgres@db:5432/furniture_ecm?schema=public

REDIS_URL=redis://redis:6379
REDIS_CACHE_PREFIX=furniture_ecm

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_URL=

# Auth / Social (OAuth: thêm đúng redirect URI trong Google Console theo NEXT_PUBLIC_SITE_URL)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
OTP_DEBUG=0

# Tracking / Contact / Frontend public
NEXT_PUBLIC_CONTACT_EMAIL=support@example.com
NEXT_PUBLIC_MESSENGER_URL=https://m.me/your-page
NEXT_PUBLIC_ZALO_URL=https://zalo.me/your-zalo-id
NEXT_PUBLIC_HOTLINE_TEL=0900000000
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# App banner
NEXT_PUBLIC_APP_MESSAGE=
NEXT_PUBLIC_ADMIN_APP_MESSAGE=
NEXT_PUBLIC_APP_MESSAGE_KIND=info

# LibreTranslate (trong Docker: để trống trừ khi có service trong compose hoặc URL công khai)
LIBRE_TRANSLATE_URL=
LIBRE_TRANSLATE_KEY=

# Upload retention (optional)
CHAT_UPLOAD_RETENTION_MS=
CHAT_UPLOAD_RETENTION_HOURS=168

# --- Chạy Node trực tiếp trên VPS (không Docker) ---
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/furniture_ecm?schema=public
# REDIS_URL=redis://127.0.0.1:6379
